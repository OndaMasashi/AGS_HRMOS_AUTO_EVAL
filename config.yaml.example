hrmos:
  base_url: "https://hrmos.co/interviews"
  login_url: "https://hrmos.co/login"  # 実際のログインURLに変更してください

# 認証情報（環境変数 HRMOS_EMAIL / HRMOS_PASSWORD でも指定可）
credentials:
  email: ""
  password: ""

# AI評価基準
evaluation_criteria:
  - name: "IT業界経験年数"
    description: "IT業界としての経験年数を経歴の執務期間と経験内容から判断してください。長いほど評価を高くします。"
  - name: "プログラミング経験"
    description: "IT開発工程におけるプログラミング開発経験（Python, JavaScript, vba等）の経験と深さ"
  - name: "設計経験"
    description: "IT開発の上流工程である要件定義や設計工程に関わる経験と深さ"
  - name: "マネジメント経験"
    description: "チームリーダー、プロジェクトマネジメント、プロジェクトリーダー、サブリーダー等の経験の有無と深さ"
  - name: "資格保有状況"
    description: "IT関連資格（AWS認定、PMP、ITIL、等）の有無と希少な資格の有無の状況"
  - name: "同一環境での長期執務"
    description: "転職回数や1回あたりの転職の間隔が2年未満であったり、1回あたりの案件の期間が3ヵ月以内が多い場合は評価を下げる"
  - name: "自己学習・成長意欲"
    description: "自己学習として業務以外で何か意欲的に取り組んでいることが分かる場合評価をする。判断できない場合は評価無しとする"

# AI評価設定
evaluation:
  provider: "claude"             # "claude" or "gemini"（デフォルト: claude）
  system_instructions: |
    書類の内容に基づいて客観的に評価してください。
    推測ではなく、書類に明記されている情報のみを根拠にしてください。
  max_retries: 3
  retry_delay: 5
  timeout: 120
  max_text_chars: 80000
  shell: false

# 面接質問生成設定
interview_questions:
  count: 3
  perspective: |
    応募者の自律性や自己成長意欲を確認する質問、マネジメント面でQCDに関する考え方を問う質問、
    スキルが伴っており表面的に業務を行ってきていないことを確認する質問、などの履歴書から読み取れない意識面を問う質問をしたい。

scan:
  download_dir: "./data/downloads"
  report_dir: "./data/reports"
  db_path: "./data/hrmos.db"
  wait_between_pages: 2        # ページ間の待機秒数（サーバー負荷軽減）
  headless: false              # true: ブラウザ非表示 / false: ブラウザ表示
  delete_downloads_after: false # true: 解析後にダウンロードファイルを削除

# メール通知設定（Resend）
email:
  enabled: false
  api_key: ""                    # 環境変数 RESEND_API_KEY でも指定可
  from: "onboarding@resend.dev"  # 送信元（独自ドメイン設定後に変更）
  to:
    - ""
  subject_prefix: "[HRMOS]"
